*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.installed.cfg

# === Virtual Environment ===
.venv/
venv/
ENV/

# === Environment / Secrets ===
.env
.env.local
.env.render
.env.production
*.local

# === Testing ===
.pytest_cache/
.coverage
htmlcov/
.hypothesis/
.ruff_cache/

# === IDE ===
.idea/
.vscode/
*.swp
*.swo

# === OS ===
.DS_Store
Thumbs.db
nul

# === Logs ===
*.log
logs/

# === Database ===
*.db
*.sqlite3

# === Node.js (wiii-desktop) ===
node_modules/

# === Tauri build artifacts ===
wiii-desktop/src-tauri/target/

# === Build outputs ===
build/
dist/
downloads/
wheels/
sdist/
develop-eggs/
eggs/
.eggs/
parts/
var/

# === Temp / generated ===
_find_untested.py
docx_output.txt
test_*.txt
/tools/

# === pip install artifacts ===
maritime-ai-service/=*

# === Local dev session files ===
2026-03-*.md
ollama-benchmark-*.json
wiii-1420.err
wiii-1420.out
test-results/
Documents/
maritime-ai-service/.tmp-workspace/
maritime-ai-service/.env.soul-agi
wiii-desktop/scripts/screenshots/

# === Claude Code artifacts ===
.claude/plans/
.claude/reports/
.claude/tasks/
/plans/

# === Large data files ===
maritime-ai-service/data/*.pdf
maritime-ai-service/data/*.csv

# === Documentation screenshots ===
docs/assets/screenshots/tmp/

# === Generated build output ===
wiii-desktop/dist-embed/
wiii-desktop/dist-web/
pytest-cache-files-*
# Keep local nested agent configs ignored, but track root Codex review guidance.
.agents/
**/AGENTS.md
!/AGENTS.md
.Codex/external/
.Codex/tmp/
.Codex/reports/
.Codex/runtime-logs/
**/.Codex/external/
**/.Codex/tmp/
**/.Codex/reports/
**/.Codex/runtime-logs/
