{
  "name": "wiii-desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "dev:visual:test:backend": "node scripts/start-visual-backend.mjs",
    "dev:visual:test:frontend": "node scripts/start-visual-frontend.mjs",
    "test:web:visual": "node scripts/run-web-visual-smoke.mjs",
    "test:web:visual:mobile": "node scripts/run-web-visual-smoke.mjs --viewport-width 390 --viewport-height 1440 --result-name web-visual-mobile-result.json --screenshot-name visual-mobile-rendered.png --user-id visual-mobile-smoke-user --display-name \"Visual Mobile Smoke\"",
    "test:e2e:visual": "playwright test -c playwright.visual.config.ts",
    "test:e2e:visual:headed": "playwright test -c playwright.visual.config.ts --headed",
    "dev:embed": "cross-env BUILD_TARGET=embed vite",
    "build:embed": "cross-env BUILD_TARGET=embed vite build && node -e \"require('fs').copyFileSync('dist-embed/embed.html','dist-embed/index.html')\"",
    "build:web": "cross-env BUILD_TARGET=web tsc && cross-env BUILD_TARGET=web vite build",
    "preview:embed": "cross-env BUILD_TARGET=embed vite preview --port 1421"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@monaco-editor/react": "^4.7.0",
    "@rive-app/react-webgl2": "^4.27.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-http": "^2.5.8",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.0.0",
    "immer": "^11.1.4",
    "katex": "^0.16.28",
    "lucide-react": "^0.400.0",
    "mermaid": "^11.14.0",
    "motion": "^12.38.0",
    "plotly.js-gl3d-dist-min": "^3.5.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "react-plotly.js": "^2.6.0",
    "react-resizable-panels": "^4.10.0",
    "react-shiki": "^0.9.3",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "simplex-noise": "^4.0.3",
    "uuid": "^14.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^15.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-plotly.js": "^2.6.4",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^7.0.3",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
