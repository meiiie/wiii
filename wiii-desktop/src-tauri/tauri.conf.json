{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Wiii",
  "version": "1.0.0",
  "identifier": "com.wiii-lab.wiii-desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Wiii",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "splashscreen",
        "title": "Wiii",
        "url": "splashscreen.html",
        "width": 480,
        "height": 340,
        "resizable": false,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true,
        "focus": true,
        "visible": true,
        "skipTaskbar": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright \u00a9 2026 The Wiii Lab",
    "shortDescription": "Wiii \u2014 AI Assistant by The Wiii Lab",
    "longDescription": "Multi-domain agentic RAG platform with long-term memory, product search, and LMS integration.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "displayLanguageSelector": false,
        "languages": ["Vietnamese", "English"],
        "customLanguageFiles": {
          "Vietnamese": "windows/Vietnamese.nsh"
        },
        "compression": "lzma"
      }
    }
  }
}
