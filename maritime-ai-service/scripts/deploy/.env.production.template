# =============================================================================
# WIII PRODUCTION ENVIRONMENT — Template
# by The Wiii Lab (Hong Linh Linh Hung)
#
# Domain: holilihu.online
#
# Usage:
#   1. Copy to maritime-ai-service/.env.production
#   2. Replace ALL "CHANGE_ME_*" values with real secrets
#   3. NEVER commit .env.production to git
#
# Generate secrets:
#   openssl rand -hex 32    # For JWT_SECRET_KEY, API_KEY
#   openssl rand -hex 16    # For database passwords
# =============================================================================

# ─────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────
APP_NAME=Wiii
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─────────────────────────────────────────────────
# SECRETS — Change ALL of these!
# ─────────────────────────────────────────────────
API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ─────────────────────────────────────────────────
# LLM — Google Gemini (primary)
# ─────────────────────────────────────────────────
LLM_PROVIDER=google
GOOGLE_API_KEY=CHANGE_ME_your_gemini_api_key
GOOGLE_MODEL=gemini-3-flash-preview

# Optional: OpenAI failover
# OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────
# DATABASE — PostgreSQL (Docker internal network)
# ─────────────────────────────────────────────────
POSTGRES_USER=wiii
POSTGRES_PASSWORD=CHANGE_ME_generate_strong_password
POSTGRES_DB=wiii_ai
# docker-compose.prod.yml overrides DATABASE_URL, but set it for standalone use:
DATABASE_URL=postgresql+asyncpg://wiii:CHANGE_ME_generate_strong_password@postgres:5432/wiii_ai

# ─────────────────────────────────────────────────
# MINIO — Object Storage (Docker internal network)
# ─────────────────────────────────────────────────
MINIO_ACCESS_KEY=wiii-admin
MINIO_SECRET_KEY=CHANGE_ME_generate_strong_password
MINIO_BUCKET=wiii-docs
MINIO_SECURE=false

# ─────────────────────────────────────────────────
# NEO4J — Graph Database (optional since Sprint 165)
# ─────────────────────────────────────────────────
# Neo4j is opt-in. Set ENABLE_NEO4J=true if you need GraphRAG.
ENABLE_NEO4J=false
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_generate_strong_password

# ─────────────────────────────────────────────────
# DOMAIN & CORS
# ─────────────────────────────────────────────────
CORS_ORIGINS=["https://holilihu.online","https://api.holilihu.online"]
CORS_ORIGIN_REGEX=https://.*\.holilihu\.online

# ─────────────────────────────────────────────────
# SUBDOMAIN ORG ROUTING (Sprint 175)
# ─────────────────────────────────────────────────
# Nginx extracts subdomain from *.holilihu.online → X-Organization-ID header
SUBDOMAIN_BASE_DOMAIN=holilihu.online
ENABLE_MULTI_TENANT=false

# ─────────────────────────────────────────────────
# DOMAIN PLUGINS
# ─────────────────────────────────────────────────
ACTIVE_DOMAINS=["maritime","traffic_law"]
DEFAULT_DOMAIN=maritime

# ─────────────────────────────────────────────────
# GOOGLE OAUTH (Sprint 157)
# ─────────────────────────────────────────────────
ENABLE_GOOGLE_OAUTH=true
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME_your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME_your_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://holilihu.online/api/v1/auth/google/callback

# ─────────────────────────────────────────────────
# CROSS-PLATFORM IDENTITY (Sprint 174)
# ─────────────────────────────────────────────────
ENABLE_CROSS_PLATFORM_IDENTITY=true
DEFAULT_PERSONALITY_MODE=professional

# ─────────────────────────────────────────────────
# FACEBOOK MESSENGER WEBHOOK (Sprint 174, 188)
# ─────────────────────────────────────────────────
ENABLE_MESSENGER_WEBHOOK=true
FACEBOOK_PAGE_ID=CHANGE_ME_your_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=CHANGE_ME_your_page_access_token
FACEBOOK_VERIFY_TOKEN=CHANGE_ME_your_verify_token
FACEBOOK_APP_SECRET=CHANGE_ME_your_app_secret
FACEBOOK_GRAPH_API_VERSION=v22.0

# ─────────────────────────────────────────────────
# ZALO OA WEBHOOK (Sprint 174, 188)
# ─────────────────────────────────────────────────
ENABLE_ZALO_WEBHOOK=true
ZALO_WEBHOOK_TOKEN=CHANGE_ME_your_zalo_webhook_token
ZALO_OA_ACCESS_TOKEN=CHANGE_ME_your_zalo_oa_access_token
ZALO_OA_SECRET_KEY=CHANGE_ME_your_zalo_secret

# ─────────────────────────────────────────────────
# SOUL AGI — Living Agent (Sprint 188)
# Enable for autonomous 24/7 Wiii Soul deployment
# ─────────────────────────────────────────────────
ENABLE_LIVING_AGENT=false
LIVING_AGENT_HEARTBEAT_INTERVAL=1800
LIVING_AGENT_ACTIVE_HOURS_START=5
LIVING_AGENT_ACTIVE_HOURS_END=23
LIVING_AGENT_ENABLE_SOCIAL_BROWSE=true
LIVING_AGENT_ENABLE_SKILL_BUILDING=true
LIVING_AGENT_ENABLE_JOURNAL=true
LIVING_AGENT_ENABLE_WEATHER=true
LIVING_AGENT_ENABLE_BRIEFING=true
LIVING_AGENT_ENABLE_ROUTINE_TRACKING=true
LIVING_AGENT_ENABLE_DYNAMIC_GOALS=true
LIVING_AGENT_ENABLE_PROACTIVE_MESSAGING=true
LIVING_AGENT_MAX_PROACTIVE_PER_DAY=3
LIVING_AGENT_REQUIRE_HUMAN_APPROVAL=false
LIVING_AGENT_AUTONOMY_LEVEL=1
LIVING_AGENT_ENABLE_AUTONOMY_GRADUATION=true
# LIVING_AGENT_LOCAL_MODEL=qwen3:4b
# OLLAMA_BASE_URL=http://ollama:11434
# OPENWEATHERMAP_API_KEY=CHANGE_ME_your_weather_key

# ─────────────────────────────────────────────────
# CLOUDFLARE TUNNEL (Sprint 188 — Soul AGI profile)
# Get token from: Cloudflare Zero Trust → Networks → Tunnels
# ─────────────────────────────────────────────────
# CF_TUNNEL_TOKEN=CHANGE_ME_your_tunnel_token

# ─────────────────────────────────────────────────
# LMS INTEGRATION (Sprint 155-159)
# ─────────────────────────────────────────────────
# ENABLE_LMS_TOKEN_EXCHANGE=false
# LMS_API_KEY=CHANGE_ME_if_lms_enabled
# LMS_BASE_URL=https://your-lms.edu.vn

# ─────────────────────────────────────────────────
# PERFORMANCE TUNING
# Soul AGI mode: Use 1 worker (heartbeat is singleton)
# ─────────────────────────────────────────────────
GUNICORN_WORKERS=4
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ─────────────────────────────────────────────────
# SEMANTIC MEMORY
# ─────────────────────────────────────────────────
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSIONS=768
SEMANTIC_MEMORY_ENABLED=true

# ─────────────────────────────────────────────────
# MULTI-AGENT
# ─────────────────────────────────────────────────
USE_MULTI_AGENT=true
ENABLE_CORRECTIVE_RAG=true

# ─────────────────────────────────────────────────
# VALKEY — Cache/Rate Limiter (Docker internal)
# ─────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0
