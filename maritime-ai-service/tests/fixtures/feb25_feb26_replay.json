          "liquidation_1m_usd": 7200000,
          "liquidation_5m_usd": 18000000,
          "imbalance": 0.81,
          "dominant_side": "LONG",
          "positions_closed": [
            {"symbol": "DOGEUSDT", "exit_reason": "STOP_LOSS", "pnl_usd": -1.20},
            {"symbol": "FETUSDT", "exit_reason": "STOP_LOSS", "pnl_usd": -1.10},
            {"symbol": "WLDUSDT", "exit_reason": "STOP_LOSS", "pnl_usd": -1.30}
