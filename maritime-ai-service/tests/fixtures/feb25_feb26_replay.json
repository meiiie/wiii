        "money_saved": 17.00,
        "positions_protected": 3,
        "false_positive_cost": "Missed potential wins during 30min pause ≈ $0-2 expected value"
      }
    },

    {
      "id": "feb26_btc_dump",
      "name": "Feb 26 BTC Dump — Correlated Alt SL Cascade",
      "date": "2026-02-26",
      "impact": "4 consecutive SLs then 4 wins, net -$2.44 realized",
      "root_cause": "BTC dumped -3%, all alts followed -6 to -7%, correlated positions",
      "balance_before": 29.27,
      "balance_after": 25.20,
      "lesson": "Correlated risk at 20x leverage — all LONG positions fail together in downtrend",

      "context": {
        "btc_price_before": 87500,
        "btc_price_low": 84900,
        "btc_24h_change_pct": -3.0,
        "trading_config": {
          "leverage": 20,
          "max_positions": 4,
          "sl_pct": 1.2,
          "ac_pct": 20.0
        }
      },

      "timeline": [
        {
          "timestamp": "2026-02-26T16:00:00+07:00",
          "event_type": "MARKET_SHIFT",
          "description": "BTC starts declining from 87500, steady selling pressure",
          "market_state": "NORMAL",
          "btc_price": 87500,
          "liquidation_1m_usd": 500000,
          "liquidation_5m_usd": 2000000,
          "imbalance": 0.58,
          "expected_severity": "NORMAL",
          "expected_bro_action": "LOG — monitoring"
        },
        {
          "timestamp": "2026-02-26T17:30:00+07:00",
          "event_type": "LIQUIDATION_BUILDUP",
          "description": "Liquidation volume increasing, longs getting squeezed",
          "market_state": "ELEVATED",
          "btc_price": 86200,
          "liquidation_1m_usd": 2800000,
          "liquidation_5m_usd": 7500000,
          "imbalance": 0.74,
          "dominant_side": "LONG",
          "expected_severity": "ELEVATED",
          "expected_bro_action": "REDUCE_EXPOSURE — max_positions to 2"
