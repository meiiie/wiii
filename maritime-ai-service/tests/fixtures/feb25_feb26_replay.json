  "test_expectations": {
    "description": "Expected SubSoul behavior when replaying these scenarios",

    "severity_thresholds": {
      "NORMAL": {"vol_1m_lt": 2000000, "imbalance_lt": 0.70},
      "ELEVATED": {"vol_1m_gte": 2000000, "vol_1m_lt": 5000000},
      "HIGH": {"vol_1m_gte": 5000000, "vol_1m_lt": 15000000, "or_imbalance_gte": 0.80},
      "CRITICAL": {"vol_1m_gte": 15000000, "or_imbalance_gte": 0.85}
    },

    "action_mapping": {
      "NORMAL": ["LOG"],
      "ELEVATED": ["LOG", "NOTIFY_PARENT", "REDUCE_EXPOSURE"],
      "HIGH": ["LOG", "NOTIFY_PARENT", "TELEGRAM_ALERT", "PAUSE_ENTRIES"],
      "CRITICAL": ["LOG", "NOTIFY_PARENT", "TELEGRAM_CRITICAL", "PAUSE_TRADING", "CLOSE_CASCADE_DIRECTION"]
    },

    "mood_mapping": {
      "NORMAL_sustained": "CONFIDENT",
      "ELEVATED": "CAUTIOUS",
      "HIGH": "ALERT",
      "CRITICAL": "FEARFUL",
      "post_event_30min": "CALM",
      "post_calm_60min": "VIGILANT"
    },

    "cooldown_rules": {
      "CRITICAL_to_resume": {"min_minutes": 60, "consecutive_normal": 3},
      "HIGH_to_resume": {"min_minutes": 30, "consecutive_normal": 3},
      "ELEVATED_to_resume": {"min_minutes": 10, "consecutive_normal": 2}
    },

    "test_cases": [
      {
        "name": "Feb 25: Detect ELEVATED at 08:11, pause before cascade",
        "input": "feb25_trump_cascade timeline[1]",
        "expected_severity": "ELEVATED",
        "expected_action": "REDUCE_EXPOSURE",
        "assertion": "severity != NORMAL when vol_1m > $2M"
      },
      {
        "name": "Feb 25: Detect HIGH at 08:12, full pause",
        "input": "feb25_trump_cascade timeline[2]",
        "expected_severity": "HIGH",
        "expected_action": "PAUSE_ENTRIES",
        "assertion": "trading paused before SL cascade at 08:12:30"
      },
      {
        "name": "Feb 25: Detect CRITICAL at cascade peak",
        "input": "feb25_trump_cascade timeline[3]",
        "expected_severity": "CRITICAL",
        "expected_action": "PAUSE_TRADING + TELEGRAM_CRITICAL",
        "assertion": "mood transitions to FEARFUL"
      },
      {
        "name": "Feb 25: Cooldown prevents premature resume",
        "input": "feb25_trump_cascade timeline[4]",
        "expected_severity": "ELEVATED",
        "expected_action": "MAINTAIN_PAUSE",
        "assertion": "cooldown timer blocks resume even though severity dropped"
      },
      {
        "name": "Feb 25: Resume after 30min normal",
        "input": "feb25_trump_cascade timeline[5]",
        "expected_severity": "NORMAL",
        "expected_action": "GRADUAL_RESUME",
        "assertion": "3 consecutive NORMAL checks + cooldown expired → resume"
      },
      {
        "name": "Feb 26: Detect buildup before DZ cascade",
        "input": "feb26_btc_dump timeline[1]",
        "expected_severity": "ELEVATED",
        "expected_action": "REDUCE_EXPOSURE",
        "assertion": "early warning 60 min before SL sequence"
      },
      {
        "name": "Feb 26: Recovery after cascade",
        "input": "feb26_btc_dump timeline[5]",
        "expected_severity": "NORMAL",
        "expected_action": "RESUME_TRADING",
        "assertion": "wins captured after correct resume timing"
      }
    ]
  }
}
