          "liquidation_1m_usd": 5500000,
          "liquidation_5m_usd": 14000000,
          "imbalance": 0.78,
          "dominant_side": "LONG",
          "expected_severity": "HIGH",
          "expected_bro_action": "PAUSE_ENTRIES — DZ already blocks entries, but Bro would add liquidation-based pause too"
