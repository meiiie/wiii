        "detection_time": "2026-02-26T17:30:00+07:00",
        "action_taken": "REDUCE + PAUSE at ELEVATED",
        "time_before_sl_cascade": "60 minutes",
        "money_saved": "~$0.95 (prevented 4th SL entry, 3 existing SLs unavoidable)",
