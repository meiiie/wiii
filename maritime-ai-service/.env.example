# =============================================================================
# WIII AI - ENVIRONMENT CONFIGURATION
# by The Wiii Lab
# =============================================================================
# Copy this file to .env and update values for your environment.
# For local development: only GOOGLE_API_KEY is required.
# All databases run via Docker Compose (docker-compose up -d).

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=Wiii
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development  # development, staging, production

# =============================================================================
# API SETTINGS
# =============================================================================
API_V1_PREFIX=/api/v1
API_KEY=your-api-key-here
LMS_API_KEY=your-lms-key-here
JWT_SECRET_KEY=change-me-in-production-use-strong-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# DATABASE - POSTGRESQL (Local Docker)
# =============================================================================
# Docker Compose maps postgres:5432 → host:5433
DATABASE_URL=postgresql+asyncpg://wiii:wiii_secret@localhost:5433/wiii_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=wiii
POSTGRES_PASSWORD=wiii_secret
POSTGRES_DB=wiii_ai

# =============================================================================
# DATABASE - NEO4J (Local Docker)
# =============================================================================
# Docker Compose maps neo4j:7687 → host:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_secret

# =============================================================================
# MINIO - LOCAL S3-COMPATIBLE OBJECT STORAGE
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=wiii
MINIO_SECRET_KEY=wiii_secret
MINIO_BUCKET=wiii-docs
MINIO_SECURE=false

# =============================================================================
# LLM SETTINGS - GOOGLE GEMINI (Primary)
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
LLM_PROVIDER=google
GOOGLE_API_KEY=your-google-gemini-api-key-here
GOOGLE_MODEL=gemini-3-flash-preview

# =============================================================================
# LLM SETTINGS - OPENROUTER (Optional fallback)
# =============================================================================
# OPENAI_API_KEY=your-openrouter-key-here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini
# OPENAI_MODEL_ADVANCED=openai/gpt-4o

# =============================================================================
# SEMANTIC MEMORY (v0.3 - Vector Embeddings)
# =============================================================================
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSIONS=768
SEMANTIC_MEMORY_ENABLED=true
SUMMARIZATION_TOKEN_THRESHOLD=2000

# =============================================================================
# MULTI-AGENT SYSTEM
# =============================================================================
USE_MULTI_AGENT=true
# Sprint 153: Removed ghost var USE_UNIFIED_AGENT (does not exist in config.py)
ENABLE_CORRECTIVE_RAG=true
RETRIEVAL_GRADE_THRESHOLD=7.0
ENABLE_ANSWER_VERIFICATION=true

# =============================================================================
# DOMAIN PLUGIN SYSTEM
# =============================================================================
ACTIVE_DOMAINS=["maritime","traffic_law"]
DEFAULT_DOMAIN=maritime

# =============================================================================
# SECURITY
# =============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# =============================================================================
# BACKGROUND TASKS (Sprint 18: Valkey + Taskiq)
# =============================================================================
# VALKEY_URL=redis://localhost:6379/0
# ENABLE_BACKGROUND_TASKS=false
# ENABLE_SCHEDULER=false

# =============================================================================
# UNIFIED PROVIDER LAYER (Sprint 55)
# =============================================================================
# ENABLE_UNIFIED_CLIENT=false        # AsyncOpenAI SDK alongside LangChain

# =============================================================================
# MCP SUPPORT (Sprint 56)
# =============================================================================
# ENABLE_MCP_SERVER=false             # Expose tools via MCP at /mcp
# ENABLE_MCP_CLIENT=false             # Connect to external MCP servers
# MCP_SERVER_CONFIGS=[]               # JSON array of MCP server configs

# =============================================================================
# AGENTIC LOOP (Sprint 57)
# =============================================================================
# ENABLE_AGENTIC_LOOP=true            # Generalized ReAct tool-calling loop (default: true)
# AGENTIC_LOOP_MAX_STEPS=8            # Max tool iterations (1-20, default: 8)

# =============================================================================
# OLLAMA ENHANCEMENT (Sprint 59)
# =============================================================================
OLLAMA_MODEL=qwen3:8b                 # Default Ollama model (was llama3.2)
OLLAMA_THINKING_MODELS=["qwen3","deepseek-r1","qwq"]

# =============================================================================
# LANGSMITH OBSERVABILITY (Sprint 144b)
# =============================================================================
# Get your API key from: https://smith.langchain.com
# ENABLE_LANGSMITH=false
# LANGSMITH_API_KEY=lsv2_pt_xxxxx
# LANGSMITH_PROJECT=wiii
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# PRODUCT SEARCH (Sprint 148-149: "Săn Hàng" + "Cắm & Chạy")
# =============================================================================
# ENABLE_PRODUCT_SEARCH=false
# SERPER_API_KEY=                       # Serper.dev key for Google Shopping (free 2,500 searches/month)
# APIFY_API_TOKEN=                      # Apify token for Shopee/TikTok/Lazada/FB scrapers
# PRODUCT_SEARCH_PLATFORMS=["google_shopping","shopee","tiktok_shop","lazada","facebook_marketplace","all_web","instagram","websosanh"]

# TikTok Research API (Sprint 149: native, free — no user login needed)
# Get credentials: https://developers.tiktok.com/ → Create App → Research API
# ENABLE_TIKTOK_NATIVE_API=false
# TIKTOK_CLIENT_KEY=                    # TikTok Developer Portal client key
# TIKTOK_CLIENT_SECRET=                 # TikTok Developer Portal client secret

# Deep Product Search (Sprint 150: "Tìm Sâu")
# PRODUCT_SEARCH_MAX_ITERATIONS=15      # Max ReAct iterations (5-30, default 15)
# PRODUCT_SEARCH_SCRAPE_TIMEOUT=10      # Page scraper timeout in seconds (3-30)
# PRODUCT_SEARCH_MAX_SCRAPE_PAGES=10    # Max pages to scrape per session (1-30)

# Browser Scraping (Sprint 152: Playwright + LLM Extraction for Facebook)
# Requires: pip install playwright && playwright install chromium
# ENABLE_BROWSER_SCRAPING=false         # Use headless Chromium for Facebook/Instagram
# BROWSER_SCRAPING_TIMEOUT=15           # Page load timeout in seconds (3-60)

# Browser Screenshots (Sprint 153: "Mắt Thần" — stream screenshots to UI)
# ENABLE_BROWSER_SCREENSHOTS=false      # Stream Playwright screenshots during search (requires ENABLE_BROWSER_SCRAPING)
# BROWSER_SCREENSHOT_QUALITY=40         # JPEG quality 10-90 (lower = smaller, ~30-50KB at 40)

# Sprint 198: Serper.dev for web/B2B search (replaces DuckDuckGo)
# ENABLE_SERPER_WEB_SEARCH=true         # Use Serper for web/dealer/intl search (requires SERPER_API_KEY, falls back to DuckDuckGo)

# =============================================================================
# LMS INTEGRATION (Sprint 175 + Sprint 220: "Cắm Phích" Production Connection)
# Full docs: docs/integration/WIII_LMS_INTEGRATION.md
# =============================================================================
# Master feature flags
# ENABLE_LMS_INTEGRATION=false           # Enable LMS webhooks, data pull, push, dashboard, agent tools, context injection
# ENABLE_LMS_TOKEN_EXCHANGE=false        # Enable HMAC-signed backend-to-backend JWT exchange

# HMAC-SHA256 shared secret (webhooks + token exchange)
# Must match LMS application.yml → wiii.webhook.secret
# Generate: openssl rand -hex 32
# LMS_WEBHOOK_SECRET=

# LMS REST API base URL (for Wiii → LMS data pull)
# LMS_BASE_URL=http://localhost:8088

# API timeout for LMS calls in seconds (range 3-60, default 10)
# LMS_API_TIMEOUT=10

# Token exchange replay protection in seconds (range 30-600, default 300)
# LMS_TOKEN_EXCHANGE_MAX_AGE=300

# Multi-LMS connector configuration (JSON array)
# Each entry: id, display_name, backend_type, base_url, service_token, webhook_secret, api_timeout, organization_id, extra
# organization_id: Wiii org to assign LMS users (fallback: connector id). Eliminates hardcoding on LMS side.
# LMS_CONNECTORS=[{"id":"maritime-lms","display_name":"LMS Hang Hai","backend_type":"spring_boot","base_url":"http://localhost:8080/api/v3","webhook_secret":"your-secret","organization_id":"maritime-lms","api_timeout":10,"extra":{"api_prefix":"api/v3/integration"}}]

# CORS — add LMS frontend domain for cross-origin requests
# (append to existing CORS_ORIGINS)
# Example: CORS_ORIGINS=["http://localhost:3000","http://localhost:4200","https://lms.maritime.edu.vn"]

# =============================================================================
# MAGIC LINK EMAIL AUTH (Sprint 224)
# =============================================================================
# Passwordless email authentication via magic links (Resend)
# ENABLE_MAGIC_LINK_AUTH=false
RESEND_API_KEY=
MAGIC_LINK_BASE_URL=http://localhost:8000
MAGIC_LINK_FROM_EMAIL=Wiii <noreply@wiii.app>

# =============================================================================
# AUTH HARDENING (Sprint 192: "Khiên Sắt")
# =============================================================================
# ENABLE_ORG_MEMBERSHIP_CHECK=true      # Validate X-Organization-ID against user_organizations
# ENABLE_JTI_DENYLIST=false             # In-memory JTI denylist for access token revocation
# JWT_AUDIENCE=wiii                     # JWT audience claim value
# ENFORCE_API_KEY_ROLE_RESTRICTION=true # Block admin role via API key in production
# OTP_MAX_GENERATE_PER_WINDOW=5         # Max OTP codes per user per 15-min window
# OTP_GENERATE_WINDOW_MINUTES=15        # OTP rate limit window (minutes)
# OTP_MAX_VERIFY_ATTEMPTS=5             # Max failed OTP attempts before lockout

# =============================================================================
# EMBED WIDGET (Sprint 220b: "Nhúng Wiii" — iframe embed for LMS)
# =============================================================================
# Space-separated list of origins allowed to iframe Wiii embed (CSP frame-ancestors)
# IMPORTANT for production: Add your LMS domain(s) here, otherwise iframe will be blocked by CSP.
# Dev: http://localhost:4200 http://localhost:61361 http://127.0.0.1:4200
# Prod: https://holilihu.online
# EMBED_ALLOWED_ORIGINS=http://localhost:4200 https://holilihu.online

# =============================================================================
# LOGGING & OBSERVABILITY
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
MASK_PII=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # Uncomment for tracing
