# =============================================================================
# WIII PRODUCTION ENVIRONMENT VARIABLES
# Copy to .env.production and fill in ALL required values
# =============================================================================

# --- Application ---
APP_NAME=Wiii
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=production
API_V1_PREFIX=/api/v1

# --- REQUIRED: LLM API Keys ---
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-3.1-flash-lite-preview
API_KEY=your-secure-api-key-here
LMS_API_KEY=your-lms-api-key-here

# --- REQUIRED: Security ---
JWT_SECRET_KEY=generate-a-random-256-bit-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
SESSION_SECRET_KEY=generate-a-random-session-secret-here
CORS_ORIGINS=["https://your-domain.com"]

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- REQUIRED: Database Passwords (change from defaults!) ---
POSTGRES_USER=wiii
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=wiii_ai
# Production: connect via socket or internal hostname, not localhost:5433
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://wiii:change-this-strong-password@postgres:5432/wiii_ai

NEO4J_USER=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-this-strong-password
NEO4J_URI=bolt://neo4j:7687

MINIO_ACCESS_KEY=wiii
MINIO_SECRET_KEY=change-this-strong-password
MINIO_BUCKET=wiii-docs
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

# --- LLM Runtime ---
LLM_PROVIDER=google
LLM_FAILOVER_CHAIN=["google","openrouter","ollama"]

# --- Recommended hybrid model runtime (OpenRouter) ---
# LLM_PROVIDER=openrouter
# LLM_FAILOVER_CHAIN=["openrouter","ollama","google"]
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-oss-20b:free
# OPENAI_MODEL_ADVANCED=openai/gpt-oss-120b:free
# OPENROUTER_MODEL_FALLBACKS=["openrouter/auto"]
# OPENROUTER_PROVIDER_ORDER=["openai","anthropic"]
# OPENROUTER_ALLOW_FALLBACKS=true
# OPENROUTER_REQUIRE_PARAMETERS=true
# OPENROUTER_PROVIDER_SORT=latency

# If Ollama runs as a sidecar/container on the same Docker network:
# OLLAMA_BASE_URL=http://ollama:11434
# If backend must call a host-native or remote Ollama instead, override the URL:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen3:4b-instruct-2507-q4_K_M
# OLLAMA_KEEP_ALIVE=30m
# OLLAMA_THINKING_MODELS=["qwen3","deepseek-r1","qwq"]

# --- Semantic Memory ---
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSIONS=768
SEMANTIC_MEMORY_ENABLED=true
SUMMARIZATION_TOKEN_THRESHOLD=2000

# --- Multi-Agent System ---
USE_MULTI_AGENT=true
ENABLE_CORRECTIVE_RAG=true
RETRIEVAL_GRADE_THRESHOLD=7.0
ENABLE_ANSWER_VERIFICATION=true

# --- Domain Plugin System ---
ACTIVE_DOMAINS=["maritime","traffic_law"]
DEFAULT_DOMAIN=maritime

# --- Optional: App Tuning ---
# GUNICORN_WORKERS=4
# APP_PORT=8000
# APP_CPU_LIMIT=2.0
# APP_MEM_LIMIT=4G

# --- Infrastructure: Rate Limiting (auto-detected from Valkey container) ---
VALKEY_URL=redis://valkey:6379/0

# --- Magic Link Email Auth (Sprint 224) ---
# ENABLE_MAGIC_LINK_AUTH=false
RESEND_API_KEY=
MAGIC_LINK_BASE_URL=https://your-domain.com
MAGIC_LINK_FROM_EMAIL=Wiii <noreply@your-domain.com>

# --- Logging & Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json
MASK_PII=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Optional: Features ---
# ENABLE_WEBSOCKET=true
# ENABLE_TELEGRAM=false
# ENABLE_MCP_SERVER=false
# ENABLE_PRIVILEGED_SANDBOX=true
# SANDBOX_PROVIDER=opensandbox
# OPENSANDBOX_BASE_URL=https://sandbox.your-domain.com
# OPENSANDBOX_API_KEY=replace-me
# OPENSANDBOX_CODE_TEMPLATE=opensandbox/code-interpreter:v1.0.1
# OPENSANDBOX_BROWSER_TEMPLATE=opensandbox/playwright:latest
# OPENSANDBOX_NETWORK_MODE=egress
# ENABLE_SCHEDULER=false
# ENABLE_MULTI_TENANT=false
